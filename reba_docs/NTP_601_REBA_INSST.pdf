           <p>Página: <span id="page_num"></span> / <span id="page_count"></span></p>
          </div> <a href="#" id="start-presentation" title="Ver en pantalla completa"> <i class="icon-opentab" aria-hidden="true"></i> <span class="sr-only">Ver en pantalla completa</span> </a>
