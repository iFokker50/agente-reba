        <script type="module">
  var url = 'https://www.insst.es/documents/94886/7861730/ntp_601.pdf/2989c14f-2280-4eef-9cb7-f195366352ba?version=1.2&t=1727418175902';

  var { pdfjsLib } = globalThis;

  pdfjsLib.GlobalWorkerOptions.workerSrc = '/o/inssbt-portal-theme/js/pdf-js/pdf.worker.mjs';

  var pdfDoc = null,
    pageNum = 1,
    pageRendering = false,
    pageNumPending = null,
    scale = 0.8,
    canvas = document.getElementById('pdf-render'),
    ctx = canvas.getContext('2d');

  /**
   * Get page info from document, resize canvas accordingly, and render page.
   * @param num Page number.
   */
  function renderPage(num) {
    pageRendering = true;
    pdfDoc.getPage(num).then(function (page) {
      var viewport = page.getViewport({ scale: scale });

      // Si el canvas está en pantalla completa, ajustar la escala
      if (document.fullscreenElement || document.webkitFullscreenElement || document.mozFullScreenElement || document.msFullscreenElement) {
        var fullscreenScale = Math.min(window.innerWidth / viewport.width, window.innerHeight / viewport.height);
        viewport = page.getViewport({ scale: fullscreenScale });
      } else {
        // Renderizado normal
        viewport = page.getViewport({ scale: scale });
      }

      canvas.width = viewport.width;
      canvas.height = viewport.height;

      // Render PDF page into canvas context
      var renderContext = {
        canvasContext: ctx,
        viewport: viewport
      };
      var renderTask = page.render(renderContext);

      renderTask.promise.then(function () {
        pageRendering = false;
        if (pageNumPending !== null) {
          renderPage(pageNumPending);
          pageNumPending = null;
        }
      });
    });

    document.getElementById('page_num').textContent = num;
  }

  /**
   * If another page rendering in progress, waits until the rendering is
   * finised. Otherwise, executes rendering immediately.
   */
  function queueRenderPage(num) {
    if (pageRendering) {
      pageNumPending = num;
    } else {
      renderPage(num);
    }
  }

  /**
   * Displays previous page.
   */
  function onPrevPage() {
    if (pageNum <= 1) {
      return;
    }
    pageNum--;
    queueRenderPage(pageNum);
  }
  document.getElementById('prev').addEventListener('click', onPrevPage);

  /**
   * Displays next page.
   */
  function onNextPage() {
    if (pageNum >= pdfDoc.numPages) {
      return;
    }
    pageNum++;
    queueRenderPage(pageNum);
  }
  document.getElementById('next').addEventListener('click', onNextPage);

  /**
   * Asynchronously downloads PDF.
   */
  pdfjsLib.getDocument(url).promise.then(function (pdfDoc_) {
    pdfDoc = pdfDoc_;
    document.getElementById('page_count').textContent = pdfDoc.numPages;
    renderPage(pageNum);
    // Ocultar el spinner una vez que el PDF esté completamente cargado
    document.getElementById('spinner').style.display = 'none';
    document.getElementById('pdf-render').style.backgroundColor = 'black';
  }).catch(function (error) {
    console.error('Error al cargar el PDF: ', error);
    document.getElementById('spinner').style.display = 'none';
  });

  // Fullscreen Presentation Mode
  function startPresentation() {
    if (canvas.requestFullscreen) {
      canvas.requestFullscreen().then(() => {
        renderPage(pageNum);
      });
    } else if (canvas.mozRequestFullScreen) { // Firefox
      canvas.mozRequestFullScreen().then(() => {
        renderPage(pageNum);
      });
    } else if (canvas.webkitRequestFullscreen) { // Chrome, Safari and Opera
      canvas.webkitRequestFullscreen().then(() => {
        renderPage(pageNum);
      });
    } else if (canvas.msRequestFullscreen) { // IE/Edge
      canvas.msRequestFullscreen().then(() => {
        renderPage(pageNum);
      });
    } else {
      renderPage(pageNum);
    }
  }

  // Asignar el eventListener al botón de presentación para escritorio
  document.getElementById('start-presentation').addEventListener('click', startPresentation);

  // Asignar el mismo eventListener al botón de presentación para móviles
  document.getElementById('start-presentation-mobile').addEventListener('click', () => {
    document.getElementsByClassName("pdf-content")[0].setAttribute('style', 'display:block !important');
    startPresentation();
  });

  document.addEventListener('fullscreenchange', () => {
    if (!document.fullscreenElement && !document.webkitFullscreenElement && !document.mozFullScreenElement && !document.msFullscreenElement) {
      if (window.matchMedia("(max-width: 768px)").matches) {
        document.getElementsByClassName("pdf-content")[0].setAttribute('style', 'display:none !important');
      }
      scale = 0.8;
      renderPage(pageNum);
    }
  });

  // Keyboard Controls for Presentation Mode
  document.addEventListener('keydown', (event) => {
    if (document.fullscreenElement || document.webkitFullscreenElement || document.mozFullScreenElement || document.msFullscreenElement) {
      switch (event.key) {
        case 'ArrowRight':
          if (pageNum < pdfDoc.numPages) {
            pageNum++;
            renderPage(pageNum);
          }
          break;
        case 'ArrowLeft':
          if (pageNum > 1) {
            pageNum--;
            renderPage(pageNum);
          }
          break;
        case 'Escape':
          if (document.exitFullscreen) {
            document.exitFullscreen();
          } else if (document.mozCancelFullScreen) { // Firefox
            document.mozCancelFullScreen();
          } else if (document.webkitExitFullscreen) { // Chrome, Safari and Opera
            document.webkitExitFullscreen();
          } else if (document.msExitFullscreen) { // IE/Edge
            document.msExitFullscreen();
          }
          break;
      }
    }
  });

  document.addEventListener('wheel', (event) => {
    if (document.fullscreenElement || document.webkitFullscreenElement || document.mozFullScreenElement || document.msFullscreenElement) {
      if (event.deltaY < 0) { // Scrolling up
        if (pageNum > 1) {
          pageNum--;
          renderPage(pageNum);
        }
      } else { // Scrolling down
        if (pageNum < pdfDoc.numPages) {
          pageNum++;
          renderPage(pageNum);
        }
      }
    }
  });

  // Variables para detectar el gesto de deslizamiento
  let touchStartX = 0;
  let touchEndX = 0;

  // Detectar el inicio del toque
  canvas.addEventListener('touchstart', (event) => {
    touchStartX = event.changedTouches[0].screenX;
  });

  // Detectar el movimiento del toque
  canvas.addEventListener('touchmove', (event) => {
    touchEndX = event.changedTouches[0].screenX;
  });

  // Detectar el final del toque
  canvas.addEventListener('touchend', () => {
    handleGesture();
  });

  function handleGesture() {
    if (touchEndX < touchStartX) {
      onNextPage();
    }
    if (touchEndX > touchStartX) {
      onPrevPage();
    }
  }
</script>
       </div>
